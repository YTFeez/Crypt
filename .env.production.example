# Production Hostinger VPS — copier vers /opt/crypt/.env

# URL publique de l'API (même domaine que le site, nginx proxy /api/)
VITE_API_URL=https://votredomaine.fr

# Secrets serveur (générez avec: openssl rand -hex 32)
TALKEO_JWT_SECRET=changez_moi_minimum_32_caracteres_aleatoires
TALKEO_ADMIN_KEY=cle_admin_pour_outil_decrypt

# Base SQLite sur le VPS
TALKEO_DATABASE_PATH=/opt/crypt/data/talkeo.db
TALKEO_API_PORT=8787

# Optionnel — webhook envoi code e-mail
# VITE_VERIFICATION_EMAIL_URL=https://votredomaine.fr/api/send-verification

# Optionnel — Supabase (sync cloud, pas nécessaire sur Hostinger)
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
